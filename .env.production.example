# Database
POSTGRES_USER=battleship
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=battleship
POSTGRES_PORT=5432
DATABASE_URL=postgresql://battleship:replace-with-a-strong-password@postgres:5432/battleship
API_DATABASE_URL=postgresql://battleship:replace-with-a-strong-password@postgres:5432/battleship

# API
API_PORT=4000
WEB_ORIGIN=https://your-domain.example

# Web build
WEB_PORT=80
VITE_API_URL=https://api.your-domain.example
VITE_SOCKET_URL=https://api.your-domain.example

# Optional turn timeout/auto-shot behavior. Leave unset to disable.
AUTO_SHOT_TIMEOUT_MS=
VITE_TURN_TIMER_SECONDS=
