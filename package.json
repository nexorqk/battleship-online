{
  "name": "battleship-online-template",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @battleship/api --filter @battleship/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @battleship/db prisma:generate",
    "db:migrate": "pnpm --filter @battleship/db prisma:migrate",
    "db:studio": "pnpm --filter @battleship/db prisma:studio",
    "test:e2e": "pnpm exec playwright test"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
