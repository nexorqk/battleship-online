# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/battleship
API_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/battleship
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=battleship
POSTGRES_PORT=5432

# API Server
API_PORT=4000
WEB_ORIGIN=http://localhost:5173
# Optional. Set to enable server-side automatic shots after inactivity.
AUTO_SHOT_TIMEOUT_MS=

# Web App (Vite — prefixed with VITE_)
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
# Optional. Set only when AUTO_SHOT_TIMEOUT_MS is enabled.
VITE_TURN_TIMER_SECONDS=
WEB_PORT=5173
