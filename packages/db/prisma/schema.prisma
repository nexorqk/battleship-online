generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id        String   @id @default(cuid())
  status    String
  state     Json
  version   Int      @default(0)

  playerAId String?
  playerBId String?
  winner    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shots     Shot[]
}

model Shot {
  id         String   @id @default(cuid())
  gameId     String
  playerId   String
  x          Int
  y          Int
  result     String
  turnNumber Int
  createdAt  DateTime @default(now())

  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
}
