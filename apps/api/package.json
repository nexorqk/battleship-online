    "@battleship/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "fastify": "^5.0.0",
    "nanoid": "^5.0.7",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.8.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
